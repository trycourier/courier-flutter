{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Update Package Version",
      "type": "node-terminal",
      "request": "launch",
      "command": "sh scripts/update_version.sh; exit",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Build Demo App",
      "type": "node-terminal",
      "request": "launch",
      "command": "sh scripts/build_demo_app.sh; exit",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Manually Release Package",
      "type": "node-terminal",
      "request": "launch",
      "command": "sh scripts/git_release.sh; exit",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run Tests",
      "type": "node-terminal",
      "request": "launch",
      "command": "sh scripts/run_tests.sh; exit",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "example_app",
      "cwd": "example",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart"
    }
  ]
}
